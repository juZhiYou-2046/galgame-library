# Galgame Library 环境配置
# 复制此文件为 .env 并根据实际情况修改

# 数据库连接（默认使用 SQLite）
DATABASE_URL=sqlite:///./data/galgame.db

# CORS 白名单（逗号分隔，允许跨域访问的前端地址）
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:3000,http://127.0.0.1:8000

# 数据存储目录（默认使用项目根目录下的 data/）
# DATA_DIR=./data

# 封面图片存储目录（默认使用项目根目录下的 covers/）
# COVERS_DIR=./covers

# 封面图片 URL 前缀
COVERS_URL=/covers

# 允许上传的图片格式（逗号分隔）
ALLOWED_IMAGE_EXTENSIONS=.jpg,.jpeg,.png,.webp

# 封面图片最大大小（字节，默认 5MB）
MAX_COVER_SIZE=5242880
